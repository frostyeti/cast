tasks:
  slow_task:
    uses: bash
    run: |
      echo "Starting task..."
      for i in {1..5}; do
        echo "Task running $i..."
        sleep 1
      done
      echo "Task done!"

  test:
    uses: docker
    with:
      image: golang:1.26
    run: go test ./...

  ello:
    uses: spell:examples/hello-world@head

  test-bun:
    uses: spell:examples/bun-with-inputs@head
    with:
      greeting: "greet"

jobs:
  slow_job:
    cron: "*/1 * * * *"
    steps:
      - slow_task
